# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# 楽天API
RAKUTEN_APP_ID=your_rakuten_app_id_here
RAKUTEN_ACCESS_KEY=your_rakuten_access_key_here
RAKUTEN_AFFILIATE_ID=your_rakuten_affiliate_id_here

# Yahoo!ショッピングAPI
YAHOO_CLIENT_ID=your_yahoo_client_id_here

# Python スクレイパー用（GitHub Actions でも使用）
# 上記の SUPABASE_URL / SERVICE_ROLE_KEY をそのままGitHub Secretsに登録する
